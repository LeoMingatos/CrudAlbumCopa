<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AlbumCopa2026.Views.pgCadFigurinhaView"
             Title="Cadastrar Figurinha"
             BackgroundColor="#0A3D2E">

    <ScrollView>
        <StackLayout Padding="20,20,20,40" Spacing="0">

            <!-- Cabeçalho da tela -->
            <StackLayout HorizontalOptions="Center" Margin="0,0,0,20">
                <Label Text="⚽ Nova Figurinha"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="#FFD700"
                       HorizontalOptions="Center"/>
                <Label Text="Copa do Mundo 2026"
                       FontSize="13"
                       TextColor="#A8D8A8"
                       HorizontalOptions="Center"/>
                <BoxView HeightRequest="2" Color="#FFD700"
                         Margin="60,10,60,0" CornerRadius="2"/>
            </StackLayout>

            <!-- FOTO DA FIGURINHA -->
            <Frame BackgroundColor="#0D2B1E"
                   CornerRadius="16"
                   Padding="16"
                   BorderColor="#2E7D52"
                   Margin="0,0,0,14">
                <StackLayout Spacing="10">
                    <Label Text="📸 Foto da Figurinha"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#FFD700"/>

                    <!-- Preview da imagem -->
                    <Frame x:Name="frmImagem"
                           BackgroundColor="#1A5C3E"
                           CornerRadius="12"
                           Padding="0"
                           HeightRequest="160"
                           BorderColor="#2E7D52"
                           HorizontalOptions="Center"
                           WidthRequest="160">
                        <Grid>
                            <Label Text="Toque para adicionar foto"
                                   TextColor="#6B9E7A"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   FontSize="13"/>
                            <Image x:Name="imgFigurinha"
                                   Aspect="AspectFill"
                                   IsVisible="False"/>
                        </Grid>
                    </Frame>

                    <StackLayout Orientation="Horizontal"
                                 HorizontalOptions="Center"
                                 Spacing="10">
                        <Button x:Name="btnAdicionarImagem"
                                Text="Selecionar Imagem"
                                BackgroundColor="#1A5C3E"
                                TextColor="#FFD700"
                                CornerRadius="20"
                                FontSize="13"
                                Padding="16,8"
                                BorderColor="#FFD700"
                                BorderWidth="1"
                                Clicked="btnAdicionarImagem_Clicked"/>
                        <Button x:Name="btnRemoverImagem"
                                Text="Remover"
                                BackgroundColor="#4A1010"
                                TextColor="#FF6B6B"
                                CornerRadius="20"
                                FontSize="13"
                                Padding="16,8"
                                IsVisible="False"
                                Clicked="btnRemoverImagem_Clicked"/>
                    </StackLayout>
                </StackLayout>
            </Frame>

            <!-- NOME DO JOGADOR -->
            <Frame BackgroundColor="#0D2B1E"
                   CornerRadius="16"
                   Padding="16"
                   BorderColor="#2E7D52"
                   Margin="0,0,0,14">
                <StackLayout Spacing="8">
                    <Label Text="👤 Nome do Jogador *"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#FFD700"/>
                    <Border BackgroundColor="#1A5C3E"
                            StrokeShape="RoundRectangle 10"
                            Stroke="#2E7D52"
                            Padding="12,4">
                        <Entry x:Name="txtNomeJogador"
                               Placeholder="Ex: Vinicius Jr."
                               PlaceholderColor="#4A7A5A"
                               TextColor="#FFFFFF"
                               BackgroundColor="Transparent"
                               FontSize="15"/>
                    </Border>
                </StackLayout>
            </Frame>

            <!-- SELEÇÃO -->
            <Frame BackgroundColor="#0D2B1E"
                   CornerRadius="16"
                   Padding="16"
                   BorderColor="#2E7D52"
                   Margin="0,0,0,14">
                <StackLayout Spacing="8">
                    <Label Text="🌍 Seleção *"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#FFD700"/>
                    <Border BackgroundColor="#1A5C3E"
                            StrokeShape="RoundRectangle 10"
                            Stroke="#2E7D52"
                            Padding="12,4">
                        <Entry x:Name="txtSelecao"
                               Placeholder="Ex: Brasil, Argentina, Portugal..."
                               PlaceholderColor="#4A7A5A"
                               TextColor="#FFFFFF"
                               BackgroundColor="Transparent"
                               FontSize="15"/>
                    </Border>
                </StackLayout>
            </Frame>

            <!-- TIPO DE FIGURINHA -->
            <Frame BackgroundColor="#0D2B1E"
                   CornerRadius="16"
                   Padding="16"
                   BorderColor="#2E7D52"
                   Margin="0,0,0,14">
                <StackLayout Spacing="8">
                    <Label Text="🎴 Tipo da Figurinha *"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#FFD700"/>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <!-- Comum -->
                        <Frame x:Name="frmComum"
                               Grid.Column="0"
                               BackgroundColor="#1A5C3E"
                               CornerRadius="10"
                               Padding="12,10"
                               BorderColor="#2E7D52">
                            <StackLayout HorizontalOptions="Center" Spacing="4">
                                <Label Text="⚪"
                                       FontSize="22"
                                       HorizontalOptions="Center"/>
                                <Label Text="Comum"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#FFFFFF"
                                       HorizontalOptions="Center"/>
                            </StackLayout>
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="tapComum_Tapped"/>
                            </Frame.GestureRecognizers>
                        </Frame>
                        <!-- Especial -->
                        <Frame x:Name="frmEspecial"
                               Grid.Column="1"
                               BackgroundColor="#1A5C3E"
                               CornerRadius="10"
                               Padding="12,10"
                               BorderColor="#2E7D52">
                            <StackLayout HorizontalOptions="Center" Spacing="4">
                                <Label Text="⭐"
                                       FontSize="22"
                                       HorizontalOptions="Center"/>
                                <Label Text="Especial"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#FFFFFF"
                                       HorizontalOptions="Center"/>
                            </StackLayout>
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="tapEspecial_Tapped"/>
                            </Frame.GestureRecognizers>
                        </Frame>
                    </Grid>
                    <Label x:Name="lblTipoSelecionado"
                           Text="Nenhum tipo selecionado"
                           FontSize="12"
                           TextColor="#6B9E7A"
                           HorizontalOptions="Center"/>
                </StackLayout>
            </Frame>

            <!-- STATUS: OBTIDO / DESEJADO -->
            <Frame BackgroundColor="#0D2B1E"
                   CornerRadius="16"
                   Padding="16"
                   BorderColor="#2E7D52"
                   Margin="0,0,0,14">
                <StackLayout Spacing="12">
                    <Label Text="📌 Status da Figurinha *"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#FFD700"/>

                    <!-- Obtido -->
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Label Grid.Column="0"
                               Text="✅"
                               FontSize="24"
                               VerticalOptions="Center"/>
                        <StackLayout Grid.Column="1" VerticalOptions="Center">
                            <Label Text="Já tenho esta figurinha"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#FFFFFF"/>
                            <Label Text="Marca como obtida na sua coleção"
                                   FontSize="11"
                                   TextColor="#A8D8A8"/>
                        </StackLayout>
                        <Switch x:Name="swObtido"
                                Grid.Column="2"
                                OnColor="#4CAF50"
                                ThumbColor="#FFFFFF"
                                VerticalOptions="Center"/>
                    </Grid>

                    <BoxView HeightRequest="1" Color="#2E7D52"/>

                    <!-- Desejado -->
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Label Grid.Column="0"
                               Text="❤️"
                               FontSize="24"
                               VerticalOptions="Center"/>
                        <StackLayout Grid.Column="1" VerticalOptions="Center">
                            <Label Text="Quero esta figurinha"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#FFFFFF"/>
                            <Label Text="Adiciona à sua lista de desejos"
                                   FontSize="11"
                                   TextColor="#A8D8A8"/>
                        </StackLayout>
                        <Switch x:Name="swDesejado"
                                Grid.Column="2"
                                OnColor="#E91E63"
                                ThumbColor="#FFFFFF"
                                VerticalOptions="Center"/>
                    </Grid>
                </StackLayout>
            </Frame>

            <!-- BOTÃO SALVAR -->
            <Button Text="💾  Salvar Figurinha"
                    FontSize="17"
                    FontAttributes="Bold"
                    BackgroundColor="#FFD700"
                    TextColor="#0A3D2E"
                    CornerRadius="14"
                    HeightRequest="54"
                    Margin="0,8,0,0"
                    Clicked="btnSalvar_Clicked"/>

            <!-- BOTÃO VOLTAR -->
            <Button Text="Voltar"
                    FontSize="15"
                    BackgroundColor="Transparent"
                    TextColor="#A8D8A8"
                    CornerRadius="14"
                    HeightRequest="44"
                    Margin="0,8,0,0"
                    BorderColor="#2E7D52"
                    BorderWidth="1"
                    Clicked="btnVoltar_Clicked"/>
        </StackLayout>
    </ScrollView>
</ContentPage>
