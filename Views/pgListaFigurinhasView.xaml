<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AlbumCopa2026.Views.pgListaFigurinhasView"
             Title="Minhas Figurinhas"
             BackgroundColor="#0A3D2E">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- CABEÇALHO -->
        <StackLayout Grid.Row="0" Padding="16,16,16,8">

            <Label Text="📋 Minhas Figurinhas"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="#FFD700"
                   HorizontalOptions="Center"/>

            <Label Text="Copa do Mundo 2026"
                   FontSize="12"
                   TextColor="#A8D8A8"
                   HorizontalOptions="Center"/>

            <BoxView HeightRequest="1"
                     Color="#2E7D52"
                     Margin="0,8,0,0"/>

        </StackLayout>

        <!-- FILTROS -->
        <Frame Grid.Row="1"
               BackgroundColor="#0D2B1E"
               CornerRadius="16"
               Padding="14"
               BorderColor="#2E7D52"
               Margin="12,0,12,8">

            <StackLayout Spacing="10">

                <!-- Busca -->
                <Border BackgroundColor="#1A5C3E"
                        StrokeShape="RoundRectangle 10"
                        Stroke="#2E7D52"
                        Padding="10,2">

                    <Grid ColumnDefinitions="Auto,*">

                        <Label Grid.Column="0"
                               Text="🔍"
                               FontSize="16"
                               VerticalOptions="Center"
                               Margin="0,0,6,0"/>

                        <Entry x:Name="txtFiltroNome"
                               Grid.Column="1"
                               Placeholder="Buscar por nome do jogador..."
                               PlaceholderColor="#4A7A5A"
                               TextColor="#FFFFFF"
                               BackgroundColor="Transparent"
                               FontSize="14"
                               TextChanged="OnFiltroAlterado"/>

                    </Grid>

                </Border>

                <!-- FILTROS -->
                <Grid ColumnDefinitions="*,*,*"
                      ColumnSpacing="8">

                    <!-- TODOS -->
                    <Frame x:Name="frmFiltroTodos"
                           Grid.Column="0"
                           BackgroundColor="#2E7D52"
                           CornerRadius="20"
                           Padding="8,6"
                           BorderColor="#FFD700">

                        <Label Text="Todos"
                               FontSize="12"
                               FontAttributes="Bold"
                               TextColor="#FFFFFF"
                               HorizontalOptions="Center"/>

                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="tapFiltroTodos_Tapped"/>
                        </Frame.GestureRecognizers>

                    </Frame>

                    <!-- OBTIDAS -->
                    <Frame x:Name="frmFiltroObtidas"
                           Grid.Column="1"
                           BackgroundColor="#1A5C3E"
                           CornerRadius="20"
                           Padding="8,6"
                           BorderColor="#2E7D52">

                        <Label Text="✅ Obtidas"
                               FontSize="12"
                               FontAttributes="Bold"
                               TextColor="#FFFFFF"
                               HorizontalOptions="Center"/>

                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="tapFiltroObtidas_Tapped"/>
                        </Frame.GestureRecognizers>

                    </Frame>

                    <!-- DESEJADAS -->
                    <Frame x:Name="frmFiltroDesejadas"
                           Grid.Column="2"
                           BackgroundColor="#1A5C3E"
                           CornerRadius="20"
                           Padding="8,6"
                           BorderColor="#2E7D52">

                        <Label Text="❤️ Desejos"
                               FontSize="12"
                               FontAttributes="Bold"
                               TextColor="#FFFFFF"
                               HorizontalOptions="Center"/>

                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="tapFiltroDesejadas_Tapped"/>
                        </Frame.GestureRecognizers>

                    </Frame>

                </Grid>

                <!-- CONTADOR -->
                <Label x:Name="lblContador"
                       Text="0 figurinhas encontradas"
                       FontSize="11"
                       TextColor="#6B9E7A"
                       HorizontalOptions="Center"/>

            </StackLayout>

        </Frame>

        <!-- LISTA -->
        <ListView x:Name="lsvFigurinhas"
                  Grid.Row="2"
                  BackgroundColor="Transparent"
                  SeparatorVisibility="None"
                  Margin="8,0,8,0">

            <ListView.ItemTemplate>

                <DataTemplate>

                    <ViewCell>

                        <Frame BackgroundColor="#0D2B1E"
                               CornerRadius="14"
                               Padding="12"
                               Margin="4,4,4,4"
                               BorderColor="#2E7D52"
                               HasShadow="True">

                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="10">

                                <!-- IMAGEM -->
                                <Frame Grid.Column="0"
                                       BackgroundColor="#1A5C3E"
                                       CornerRadius="10"
                                       Padding="0"
                                       WidthRequest="64"
                                       HeightRequest="64"
                                       BorderColor="#2E7D52">

                                    <Image Source="{Binding DirImagem}"
                                           Aspect="AspectFill"
                                           WidthRequest="64"
                                           HeightRequest="64"/>

                                </Frame>

                                <!-- DADOS -->
                                <StackLayout Grid.Column="1"
                                             VerticalOptions="Center"
                                             Spacing="3">

                                    <Label Text="{Binding NomeJogador}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="#FFFFFF"
                                           LineBreakMode="TailTruncation"/>

                                    <StackLayout Orientation="Horizontal"
                                                 Spacing="6">

                                        <Label Text="{Binding Selecao}"
                                               FontSize="12"
                                               TextColor="#A8D8A8"/>

                                        <Label Text="•"
                                               FontSize="12"
                                               TextColor="#4A7A5A"/>

                                        <Label Text="{Binding TipoFigurinha}"
                                               FontSize="12"
                                               TextColor="#FFD700"/>

                                    </StackLayout>

                                </StackLayout>

                                <!-- AÇÕES -->
                                <StackLayout Grid.Column="2"
                                             VerticalOptions="Center"
                                             Spacing="8">

                                    <!-- OBTIDO -->
                                    <Label x:Name="lblCheck"
                                           Text="{Binding ObtidoIcon}"
                                           FontSize="22"
                                           HorizontalOptions="Center">

                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Tapped="tapToggleObtido_Tapped"
                                                CommandParameter="{Binding .}"/>
                                        </Label.GestureRecognizers>

                                    </Label>

                                    <!-- DESEJADO -->
                                    <Label Text="{Binding DesejadoIcon}"
                                           FontSize="22"
                                           HorizontalOptions="Center">

                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Tapped="tapToggleDesejado_Tapped"
                                                CommandParameter="{Binding .}"/>
                                        </Label.GestureRecognizers>

                                    </Label>

                                    <!-- DELETAR -->
                                    <Label Text="🗑️"
                                           FontSize="20"
                                           HorizontalOptions="Center">

                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Tapped="tapDeletar_Tapped"
                                                CommandParameter="{Binding .}"/>
                                        </Label.GestureRecognizers>

                                    </Label>

                                </StackLayout>

                            </Grid>

                        </Frame>

                    </ViewCell>

                </DataTemplate>

            </ListView.ItemTemplate>

        </ListView>

    </Grid>

</ContentPage>