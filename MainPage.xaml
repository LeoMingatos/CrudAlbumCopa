<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AlbumCopa2026.MainPage"
             BackgroundColor="#061B14"
             NavigationPage.HasNavigationBar="False">

    <ScrollView>

        <VerticalStackLayout Spacing="0">

            <!-- BANNER -->
            <Grid HeightRequest="260">

                <!-- IMAGEM -->
                <Image Source="banner.png"
                       Aspect="AspectFill"/>

                <!-- OVERLAY -->
                <BoxView BackgroundColor="#70000000"/>

                <!-- TEXTO -->
                <VerticalStackLayout VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="6">

                    <Label Text="🏆 Rumo ao Hexa"
                           FontSize="40"
                           FontAttributes="Bold"
                           TextColor="#FFD700"
                           HorizontalTextAlignment="Center"/>

                    <Label Text="Sua coleção oficial da Copa 2026"
                           FontSize="15"
                           TextColor="White"
                           HorizontalTextAlignment="Center"/>

                </VerticalStackLayout>

            </Grid>

            <!-- CONTEÚDO -->
            <VerticalStackLayout Padding="24,24"
                                 Spacing="22">

                <!-- BOTÕES -->
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="18">

                    <!-- CARD CADASTRAR -->
                    <Frame Grid.Column="0"
                           CornerRadius="28"
                           Padding="0"
                           BorderColor="#FFD700"
                           HasShadow="False"
                           HeightRequest="240">

                        <Grid>

                            <!-- IMAGEM FUNDO -->
                            <Image Source="cadastro.png"
                                   Aspect="AspectFill"/>

                            <!-- OVERLAY -->
                            <BoxView BackgroundColor="#90000000"/>

                            <!-- LINHA PREMIUM -->
                            <BoxView HeightRequest="5"
                                     VerticalOptions="Start"
                                     BackgroundColor="#FFD700"/>

                            <!-- TEXTO -->
                            <VerticalStackLayout VerticalOptions="Center"
                                                 HorizontalOptions="Center"
                                                 Spacing="10">

                                <Label Text="Cadastrar"
                                       FontSize="28"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalTextAlignment="Center"/>

                                <Label Text="Adicionar novas figurinhas"
                                       FontSize="14"
                                       TextColor="#E0E0E0"
                                       HorizontalTextAlignment="Center"/>

                            </VerticalStackLayout>

                            <!-- CLICK -->
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="btnCadastrar_Tapped"/>
                            </Grid.GestureRecognizers>

                        </Grid>

                    </Frame>

                    <!-- CARD LISTA -->
                    <Frame Grid.Column="1"
                           CornerRadius="28"
                           Padding="0"
                           BorderColor="#FFD700"
                           HasShadow="False"
                           HeightRequest="240">

                        <Grid>

                            <!-- IMAGEM FUNDO -->
                            <Image Source="lista.jpg"
                                   Aspect="AspectFill"/>

                            <!-- OVERLAY -->
                            <BoxView BackgroundColor="#90000000"/>

                            <!-- LINHA PREMIUM -->
                            <BoxView HeightRequest="5"
                                     VerticalOptions="Start"
                                     BackgroundColor="#FFD700"/>

                            <!-- TEXTO -->
                            <VerticalStackLayout VerticalOptions="Center"
                                                 HorizontalOptions="Center"
                                                 Spacing="10">

                                <Label Text="Coleção"
                                       FontSize="28"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalTextAlignment="Center"/>

                                <Label Text="Veja sua coleção"
                                       FontSize="14"
                                       TextColor="#E0E0E0"
                                       HorizontalTextAlignment="Center"/>

                            </VerticalStackLayout>

                            <!-- CLICK -->
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="btnLista_Tapped"/>
                            </Grid.GestureRecognizers>

                        </Grid>

                    </Frame>

                </Grid>

                <!-- TEXTO COPA -->
                <VerticalStackLayout Spacing="4"
                                     Padding="0,4,0,0">

                    <Label Text="🌎 COPA DO MUNDO 2026"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="#FFD700"
                           HorizontalTextAlignment="Center"/>

                    <Label Text="Canadá • EUA • México"
                           FontSize="15"
                           TextColor="White"
                           HorizontalTextAlignment="Center"/>

                </VerticalStackLayout>

            </VerticalStackLayout>

            <!-- RODAPÉ -->
            <VerticalStackLayout Padding="20,10,20,35"
                                 HorizontalOptions="Center"
                                 Spacing="6">

                <BoxView HeightRequest="1"
                         WidthRequest="260"
                         BackgroundColor="#2E7D52"/>

                <Label Text="Versão v1.0.0"
                       FontSize="12"
                       TextColor="#7CB08A"
                       HorizontalOptions="Center"/>

                <Label Text="Leonardo Mingatos • Eduardo Dias"
                       FontSize="11"
                       TextColor="#5D8F6C"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"/>

            </VerticalStackLayout>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>